# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bildyapp

# --- JWT ---
JWT_SECRET=cambiar_esta_clave_por_una_larga_y_random
JWT_REFRESH_SECRET=otra_clave_distinta_para_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Uploads ---
UPLOAD_MAX_MB=2

# --- Cloudinary (firmas y pdfs de albaranes) ---
# si no se rellena el storage hace fallback en memoria
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP (email de verificacion) ---
# si no esta SMTP_HOST nodemailer cae a jsonTransport (sale por consola)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Bildyapp <no-reply@bildy.test>

# --- Slack (notificacion de errores 5XX) ---
SLACK_WEBHOOK=
