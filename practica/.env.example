# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- MongoDB Atlas ---
# pendiente: rellenar con la URI real que me den en clase
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bildyapp

# --- JWT ---
# generar una cadena larga (minimo 32 chars aleatorios)
JWT_SECRET=cambiar_esta_clave_por_una_larga_y_random
JWT_REFRESH_SECRET=otra_clave_distinta_para_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Uploads ---
UPLOAD_MAX_MB=2
