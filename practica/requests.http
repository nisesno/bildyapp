@host = http://localhost:3000
@accessToken = PEGAR_ACCESS_TOKEN
@refreshToken = PEGAR_REFRESH_TOKEN
@clientId = PEGAR_ID_CLIENTE
@projectId = PEGAR_ID_PROYECTO
@noteId = PEGAR_ID_ALBARAN


### --- USUARIOS ---

### register
POST {{host}}/api/user/register
Content-Type: application/json

{
  "email": "alumno@bildy.test",
  "password": "Password123"
}


### validar email (codigo sale en consola del server)
PUT {{host}}/api/user/validation
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "123456"
}


### login
POST {{host}}/api/user/login
Content-Type: application/json

{
  "email": "alumno@bildy.test",
  "password": "Password123"
}


### onboarding
PUT {{host}}/api/user/register
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Ana",
  "lastName": "Garcia Lopez",
  "nif": "12345678Z"
}


### company - business
PATCH {{host}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "business",
  "name": "Bildy SL",
  "cif": "B12345678",
  "street": "Calle Falsa",
  "number": 123,
  "postal": "28080",
  "city": "Madrid",
  "province": "Madrid"
}


### get me
GET {{host}}/api/user
Authorization: Bearer {{accessToken}}


### refresh
POST {{host}}/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}


### logout
POST {{host}}/api/user/logout
Authorization: Bearer {{accessToken}}


### delete soft
DELETE {{host}}/api/user?soft=true
Authorization: Bearer {{accessToken}}


### --- CLIENTES ---

### crear cliente
POST {{host}}/api/client
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Garcia Reformas SL",
  "cif": "B87654321",
  "email": "garcia@cliente.test",
  "phone": "600111222",
  "address": {
    "street": "Calle Mayor",
    "number": 5,
    "postal": "28013",
    "city": "Madrid",
    "province": "Madrid"
  }
}


### listar clientes (paginado, filtro por nombre)
GET {{host}}/api/client?page=1&limit=10&name=Garcia
Authorization: Bearer {{accessToken}}


### un cliente
GET {{host}}/api/client/{{clientId}}
Authorization: Bearer {{accessToken}}


### actualizar
PUT {{host}}/api/client/{{clientId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "600999888"
}


### archivar (soft)
DELETE {{host}}/api/client/{{clientId}}?soft=true
Authorization: Bearer {{accessToken}}


### archivados
GET {{host}}/api/client/archived
Authorization: Bearer {{accessToken}}


### restaurar
PATCH {{host}}/api/client/{{clientId}}/restore
Authorization: Bearer {{accessToken}}


### --- PROYECTOS ---

### crear proyecto
POST {{host}}/api/project
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Reforma cocina",
  "projectCode": "PRJ-001",
  "client": "{{clientId}}",
  "notes": "Empieza el lunes"
}


### listar proyectos por cliente
GET {{host}}/api/project?client={{clientId}}&active=true
Authorization: Bearer {{accessToken}}


### archivar
DELETE {{host}}/api/project/{{projectId}}?soft=true
Authorization: Bearer {{accessToken}}


### --- ALBARANES ---

### crear albaran de horas (1 trabajador)
POST {{host}}/api/deliverynote
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "format": "hours",
  "hours": 8,
  "description": "Dia normal"
}


### crear albaran de horas (varios trabajadores)
POST {{host}}/api/deliverynote
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "format": "hours",
  "workers": [
    { "name": "Juan",  "hours": 8 },
    { "name": "Maria", "hours": 6 }
  ]
}


### crear albaran de material
POST {{host}}/api/deliverynote
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "format": "material",
  "material": "Cemento",
  "quantity": 25,
  "unit": "saco"
}


### listar (paginado + filtros)
GET {{host}}/api/deliverynote?project={{projectId}}&format=hours&from=2026-01-01
Authorization: Bearer {{accessToken}}


### un albaran (con populate)
GET {{host}}/api/deliverynote/{{noteId}}
Authorization: Bearer {{accessToken}}


### descargar pdf (si esta firmado redirige al de la nube)
GET {{host}}/api/deliverynote/pdf/{{noteId}}
Authorization: Bearer {{accessToken}}


### firmar (multipart con la imagen)
PATCH {{host}}/api/deliverynote/{{noteId}}/sign
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----boundary

------boundary
Content-Disposition: form-data; name="signature"; filename="firma.png"
Content-Type: image/png

< ./firma.png
------boundary--


### borrar albaran (no permitido si esta firmado)
DELETE {{host}}/api/deliverynote/{{noteId}}
Authorization: Bearer {{accessToken}}


### --- HEALTH ---
GET {{host}}/api/health
